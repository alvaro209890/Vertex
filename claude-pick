#!/usr/bin/env bash
# claude-pick - DeepSeek-only model picker for Anthropic-compatible clients.
# Usage: claude-pick [extra client args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${CLAUDE_PICK_ENV_FILE:-$SCRIPT_DIR/.env}"
PORT="${CLAUDE_PICK_PORT:-8083}"
BASE_URL="http://localhost:$PORT"

read_env_value() {
    local key="$1"
    [[ -f "$ENV_FILE" ]] || return 0

    local raw
    raw="$(grep -E "^[[:space:]]*${key}[[:space:]]*=" "$ENV_FILE" | tail -n 1 || true)"
    raw="${raw#*=}"
    raw="${raw%%#*}"
    raw="$(echo "$raw" | xargs || true)"
    raw="${raw%\"}"
    raw="${raw#\"}"
    raw="${raw%\'}"
    raw="${raw#\'}"
    echo "$raw"
}

if ! command -v fzf >/dev/null 2>&1; then
    echo "Error: fzf is required for the model picker." >&2
    echo "Install it from: https://github.com/junegunn/fzf" >&2
    exit 1
fi

models="$(
    printf "%s\n" \
        "deepseek/deepseek-v4-flash" \
        "deepseek/deepseek-v4-pro" \
        "deepseek/deepseek-chat" \
        "deepseek/deepseek-reasoner"
)"

model="$(printf "%s\n" "$models" | fzf --prompt="Select a DeepSeek model> " --height=40% --reverse)"

if [[ -z "${model:-}" ]]; then
    echo "No model selected." >&2
    exit 1
fi

auth_token="${ANTHROPIC_AUTH_TOKEN:-$(read_env_value ANTHROPIC_AUTH_TOKEN)}"
if [[ -z "$auth_token" ]]; then
    auth_token="freecc"
fi

if [[ "$auth_token" != *:* ]]; then
    auth_token="$auth_token:$model"
fi

echo "Launching Anthropic-compatible client with DeepSeek model: $model" >&2
ANTHROPIC_AUTH_TOKEN="$auth_token" ANTHROPIC_BASE_URL="$BASE_URL" exec claude "$@"
