#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ -x "$SCRIPT_DIR/.venv/bin/python" ]; then
    exec "$SCRIPT_DIR/.venv/bin/python" -c 'from cli.entrypoints import cli; cli()' "$@"
fi

if command -v python3 >/dev/null 2>&1; then
    export PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}"
    exec python3 -c 'from cli.entrypoints import cli; cli()' "$@"
fi

echo "Error: Python 3 is required to run Vertex." >&2
exit 1
